// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum SystemRole {
  ADMIN
  PO
  BA
  DEV
  TESTER
}

enum ProjectRole {
  OWNER
  PO
  BA
  DEV
  TESTER
  VIEWER
}

enum DocCategory {
  MANAGEMENT
  REQUIREMENTS
  TECHNICAL
  TESTING
  TASKS
  KNOWLEDGE
  HISTORY
}

enum DocRole {
  PO
  BA
  DEV
  TESTER
  ALL
}

enum DocStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum AttachmentKind {
  IMAGE
  PDF
  EXCEL
  LINK
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  APPROVE
  ARCHIVE
  RESTORE
  LOGIN
  LOGIN_FAILED
  ROLE_CHANGE
  MEMBER_ADD
  MEMBER_REMOVE
  ASSIGN
  COMMENT
  EXPORT
}

// ============================================================
// CORE MODELS
// ============================================================

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  fullName          String
  avatarUrl         String?
  department        String?
  systemRole        SystemRole @default(DEV)
  isActive          Boolean    @default(true)
  mustResetPassword Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  lastLoginAt       DateTime?

  projectMemberships ProjectMember[]
  createdProjects    Project[]         @relation("ProjectCreatedBy")
  documentsAuthored  Document[]        @relation("DocumentAuthor")
  documentVersions   DocumentVersion[]
  attachments        Attachment[]
  comments           Comment[]
  tasksAssigned      Task[]            @relation("TaskAssignee")
  tasksCreated       Task[]            @relation("TaskCreatedBy")
  taskHistory        TaskHistory[]
  auditLogs          AuditLog[]
  mentionsReceived   CommentMention[]
  templatesCreated   Template[]

  @@index([systemRole, isActive])
}

model Project {
  id            String          @id @default(cuid())
  name          String
  code          String          @unique
  description   String?
  icon          String?
  startDate     DateTime?
  endDate       DateTime?
  priority      ProjectPriority @default(MEDIUM)
  status        ProjectStatus   @default(ACTIVE)
  highlightNote String?

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  subsystemId String?
  subsystem   ProjectSubsystem? @relation(fields: [subsystemId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  archivedAt  DateTime?
  deletedAt   DateTime?

  members   ProjectMember[]
  modules   Module[]
  documents Document[]
  tasks     Task[]

  @@index([status, deletedAt])
  @@index([subsystemId])
}

model ProjectSubsystem {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(DEV)
  addedAt   DateTime    @default(now())

  project                 Project                                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                    User                                   @relation(fields: [userId], references: [id])
  documentTypeAssignments ProjectMemberDocumentTypeAssignment[]

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectMemberDocumentTypeAssignment {
  id              String   @id @default(cuid())
  projectMemberId String
  moduleId        String
  createdAt       DateTime @default(now())

  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  module        Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, moduleId])
  @@index([moduleId])
}

model Module {
  id        String    @id @default(cuid())
  projectId String
  name      String
  icon      String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents Document[]
  tasks     Task[]
  memberAssignments ProjectMemberDocumentTypeAssignment[]

  @@index([projectId, sortOrder])
}

model Document {
  id               String      @id @default(cuid())
  projectId        String
  moduleId         String
  title            String
  category         DocCategory
  role             DocRole
  status           DocStatus   @default(DRAFT)
  description      String?
  currentContent   String
  currentVersionNo Int         @default(1)
  diagramUrl       String?
  diagramTitle     String?
  templateId       String?

  authorId String
  author   User   @relation("DocumentAuthor", fields: [authorId], references: [id])

  parentDocumentId String?
  parentDocument    Document?  @relation("DocumentFlows", fields: [parentDocumentId], references: [id])
  childDocuments    Document[] @relation("DocumentFlows")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module      Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  versions    DocumentVersion[]
  attachments Attachment[]
  comments    Comment[]
  tasks       Task[]

  @@index([projectId, moduleId, category, status])
  @@index([projectId, moduleId, role])
  @@index([parentDocumentId])
}

model DocumentVersion {
  id          String      @id @default(cuid())
  documentId  String
  versionNo   Int
  title       String
  category    DocCategory
  role        DocRole
  status      DocStatus
  description String?
  content     String
  changeNote  String?
  createdAt   DateTime    @default(now())

  editedById String
  editedBy   User   @relation(fields: [editedById], references: [id])

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNo])
  @@index([documentId])
}

model Attachment {
  id           String         @id @default(cuid())
  documentId   String
  kind         AttachmentKind
  fileName     String?
  url          String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime       @default(now())

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Comment {
  id         String    @id @default(cuid())
  documentId String?
  taskId     String?
  authorId   String
  content    String
  quotedText String?
  resolved   Boolean   @default(false)
  parentId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  document Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  task     Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")
  mentions CommentMention[]

  @@index([documentId])
  @@index([taskId])
}

model CommentMention {
  id        String  @id @default(cuid())
  commentId String
  userId    String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  moduleId    String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  sortOrder   Int          @default(0)
  pinned      Boolean      @default(false)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdById String
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id])

  relatedDocumentId String?
  relatedDocument   Document? @relation(fields: [relatedDocumentId], references: [id], onDelete: SetNull)
  sourceHighlight   String?
  isReviewRequest   Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  comments Comment[]
  history  TaskHistory[]

  @@index([projectId, moduleId, status])
  @@index([assigneeId, status])
  @@index([dueDate])
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Template {
  id          String    @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean   @default(false)
  structure   Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  projects Project[]

  @@index([isDefault])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String?
  projectId  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([projectId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
