// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum SystemRole {
  ADMIN
  PO
  BA
  DEV
  TESTER
}

enum ProjectRole {
  OWNER
  PO
  BA
  DEV
  TESTER
  VIEWER
}

enum DocCategory {
  MANAGEMENT
  REQUIREMENTS
  TECHNICAL
  TESTING
  TASKS
  KNOWLEDGE
  HISTORY
}

enum DocRole {
  PO
  BA
  DEV
  TESTER
  ALL
}

enum DocStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum ContentFormat {
  MARKDOWN
  HTML
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  CODE_REVIEW
  READY_FOR_QA
  TESTING
  BUG_FIXING
  REOPENED
  READY_FOR_UAT
  DONE
  CANCELLED
  BLOCKED
}

enum TaskType {
  EPIC
  STORY
  TASK
  SUBTASK
  BUG
  IMPROVEMENT
  RESEARCH
  DOCUMENTATION
  TEST
  UAT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TestEstimateSource {
  AUTO
  MANUAL
}

enum TaskWorkType {
  DEV
  TEST
  BA
  PM
  REVIEW
  OTHER
}

enum CommentMentionStatus {
  PENDING
  SEEN
  RESOLVED
}

enum BugSeverity {
  MINOR
  MEDIUM
  MAJOR
  CRITICAL
  BLOCKER
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  CLOSED
  REOPENED
}

enum TestCaseStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum TestRunStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum TestResultStatus {
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

enum EpicStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum AttachmentKind {
  IMAGE
  PDF
  EXCEL
  LINK
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  APPROVE
  ARCHIVE
  RESTORE
  LOGIN
  LOGIN_FAILED
  ROLE_CHANGE
  MEMBER_ADD
  MEMBER_REMOVE
  ASSIGN
  COMMENT
  EXPORT
}

// ============================================================
// CORE MODELS
// ============================================================

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  fullName          String
  avatarUrl         String?
  department        String?
  systemRole        SystemRole @default(DEV)
  isActive          Boolean    @default(true)
  mustResetPassword Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  lastLoginAt       DateTime?

  projectMemberships ProjectMember[]
  createdProjects    Project[]         @relation("ProjectCreatedBy")
  documentsAuthored  Document[]        @relation("DocumentAuthor")
  documentVersions   DocumentVersion[]
  attachments        Attachment[]
  comments           Comment[]
  tasksAssigned      Task[]            @relation("TaskAssignee")
  tasksReported      Task[]            @relation("TaskReporter")
  tasksReviewing     Task[]            @relation("TaskReviewer")
  tasksTesting       Task[]            @relation("TaskTester")
  tasksCreated       Task[]            @relation("TaskCreatedBy")
  taskHistory        TaskHistory[]
  auditLogs          AuditLog[]
  mentionsReceived   CommentMention[]
  notifications      Notification[]
  templatesCreated   Template[]

  epicsCreated        Epic[]
  sprintsCreated      Sprint[]
  milestonesCreated   Milestone[]
  taskAssignments     TaskAssignment[] @relation("TaskAssignmentUser")
  taskAssignmentsMade TaskAssignment[] @relation("TaskAssignmentAssignedBy")
  timeLogs            TimeLog[]
  bugsReported        Bug[]            @relation("BugReportedBy")
  bugsAssigned        Bug[]            @relation("BugAssignedTo")
  bugsFixed           Bug[]            @relation("BugFixedBy")
  bugsVerified        Bug[]            @relation("BugVerifiedBy")
  testCasesCreated    TestCase[]
  testRunsCreated     TestRun[]
  testResultsExecuted TestResult[]
  aiUsageLogs         AiUsageLog[]

  @@index([systemRole, isActive])
}

model Project {
  id            String          @id @default(cuid())
  name          String
  code          String          @unique
  description   String?
  icon          String?
  startDate     DateTime?
  endDate       DateTime?
  priority      ProjectPriority @default(MEDIUM)
  status        ProjectStatus   @default(ACTIVE)
  highlightNote String?
  kanbanStatusOrder Json @default("[]")

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  subsystemId String?
  subsystem   ProjectSubsystem? @relation(fields: [subsystemId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?
  deletedAt   DateTime?

  members   ProjectMember[]
  modules   Module[]
  documents Document[]
  tasks     Task[]

  epics      Epic[]
  sprints    Sprint[]
  milestones Milestone[]
  bugs       Bug[]
  testCases  TestCase[]
  testRuns   TestRun[]
  snapshots  DailyProjectSnapshot[]
  aiUsageLogs AiUsageLog[]

  @@index([status, deletedAt])
  @@index([subsystemId])
}

model ProjectSubsystem {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(DEV)
  addedAt   DateTime    @default(now())

  project                 Project                               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                    User                                  @relation(fields: [userId], references: [id])
  documentTypeAssignments ProjectMemberDocumentTypeAssignment[]

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectMemberDocumentTypeAssignment {
  id              String   @id @default(cuid())
  projectMemberId String
  moduleId        String
  createdAt       DateTime @default(now())

  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  module        Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, moduleId])
  @@index([moduleId])
}

model Module {
  id        String    @id @default(cuid())
  projectId String
  name      String
  icon      String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project           Project                               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents         Document[]
  tasks             Task[]
  memberAssignments ProjectMemberDocumentTypeAssignment[]

  @@index([projectId, sortOrder])
}

model Document {
  id               String        @id @default(cuid())
  projectId        String
  moduleId         String
  title            String
  category         DocCategory
  role             DocRole
  status           DocStatus     @default(DRAFT)
  description      String?
  currentContent   String
  contentFormat    ContentFormat @default(MARKDOWN)
  currentVersionNo Int           @default(1)
  diagramUrl       String?
  diagramTitle     String?
  templateId       String?

  authorId String
  author   User   @relation("DocumentAuthor", fields: [authorId], references: [id])

  parentDocumentId String?
  parentDocument   Document?  @relation("DocumentFlows", fields: [parentDocumentId], references: [id])
  childDocuments   Document[] @relation("DocumentFlows")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module      Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  versions    DocumentVersion[]
  attachments Attachment[]
  comments    Comment[]
  tasks       Task[]
  relatedTasks TaskRelatedDocument[]

  @@index([projectId, moduleId, category, status])
  @@index([projectId, moduleId, role])
  @@index([parentDocumentId])
}

model DocumentVersion {
  id            String        @id @default(cuid())
  documentId    String
  versionNo     Int
  title         String
  category      DocCategory
  role          DocRole
  status        DocStatus
  description   String?
  content       String
  contentFormat ContentFormat @default(MARKDOWN)
  changeNote    String?
  createdAt     DateTime      @default(now())

  editedById String
  editedBy   User   @relation(fields: [editedById], references: [id])

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNo])
  @@index([documentId])
}

model Attachment {
  id         String         @id @default(cuid())
  documentId String
  kind       AttachmentKind
  fileName   String?
  url        String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime       @default(now())

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model Comment {
  id         String    @id @default(cuid())
  documentId String?
  taskId     String?
  authorId   String
  content    String
  quotedText String?
  resolved   Boolean   @default(false)
  parentId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  document Document?        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  task     Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author   User             @relation(fields: [authorId], references: [id])
  parent   Comment?         @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[]        @relation("CommentReplies")
  mentions CommentMention[]

  @@index([documentId])
  @@index([taskId])
}

model CommentMention {
  id         String               @id @default(cuid())
  commentId  String
  userId     String
  status     CommentMentionStatus @default(PENDING)
  resolvedAt DateTime?
  createdAt  DateTime             @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
  @@index([userId, status])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  title      String
  content    String?
  entityType String?
  entityId   String?
  projectId  String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([entityType, entityId])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  moduleId    String?
  taskCode    String?
  title       String
  description String?
  type        TaskType     @default(TASK)
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  severity    BugSeverity?
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?
  sortOrder   Int          @default(0)
  pinned      Boolean      @default(false)

  estimateHours   Decimal @default(0) @db.Decimal(10, 2)
  actualHours     Decimal @default(0) @db.Decimal(10, 2)
  storyPoint      Decimal @default(0) @db.Decimal(10, 2)
  progressPercent Int     @default(0)

  devEstimateHours        Decimal            @default(0) @db.Decimal(10, 2)
  testEstimateHours       Decimal            @default(0) @db.Decimal(10, 2)
  testEstimateSource      TestEstimateSource @default(AUTO)
  standardEstimateMandays Decimal            @default(0) @db.Decimal(10, 2)
  actualDevHours          Decimal            @default(0) @db.Decimal(10, 2)
  actualTestHours         Decimal            @default(0) @db.Decimal(10, 2)
  plannedStartAt          DateTime?
  devDueAt                DateTime?
  testDueAt               DateTime?
  estimateWarningFlag     String?
  isDevOverdue            Boolean            @default(false)
  isTestOverdue           Boolean            @default(false)
  isBlocked               Boolean            @default(false)

  blockedReason      String?
  acceptanceCriteria String?
  requirementId      String?

  epicId       String?
  epic         Epic?      @relation(fields: [epicId], references: [id], onDelete: SetNull)
  sprintId     String?
  sprint       Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  milestoneId  String?
  milestone    Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  parentTaskId String?
  parentTask   Task?      @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks     Task[]     @relation("TaskSubtasks")

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId String?
  reporter   User?   @relation("TaskReporter", fields: [reporterId], references: [id])
  reviewerId String?
  reviewer   User?   @relation("TaskReviewer", fields: [reviewerId], references: [id])
  testerId   String?
  tester     User?   @relation("TaskTester", fields: [testerId], references: [id])

  createdById String
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id])

  relatedDocumentId String?
  relatedDocument   Document? @relation(fields: [relatedDocumentId], references: [id], onDelete: SetNull)
  relatedDocuments  TaskRelatedDocument[]
  externalLinks     Json      @default("[]")
  sourceHighlight   String?
  isReviewRequest   Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module  Module? @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  comments     Comment[]
  history      TaskHistory[]
  assignments  TaskAssignment[]
  dependencies TaskDependency[] @relation("TaskDependent")
  dependents   TaskDependency[] @relation("TaskDependsOn")
  timeLogs     TimeLog[]
  bugs         Bug[]
  testCases    TestCase[]
  testResults  TestResult[]

  @@index([projectId, moduleId, status])
  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([testerId, status])
  @@index([epicId])
  @@index([sprintId])
  @@index([milestoneId])
  @@index([dueDate])
  @@index([createdAt])
}

model TaskRelatedDocument {
  id         String   @id @default(cuid())
  taskId     String
  documentId String
  createdAt  DateTime @default(now())

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([taskId, documentId])
  @@index([documentId])
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  field     String
  oldValue  String?
  newValue  String?
  reason    String?
  createdAt DateTime @default(now())

  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model Epic {
  id          String     @id @default(cuid())
  projectId   String
  epicCode    String
  name        String
  description String?
  status      EpicStatus @default(OPEN)
  startDate   DateTime?
  dueDate     DateTime?

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, epicCode])
  @@index([projectId, status])
}

model Sprint {
  id        String       @id @default(cuid())
  projectId String
  name      String
  goal      String?
  status    SprintStatus @default(PLANNED)
  startDate DateTime
  endDate   DateTime

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks    Task[]
  testRuns TestRun[]

  @@index([projectId, status])
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  name        String
  description String?
  status      MilestoneStatus @default(PLANNED)
  dueDate     DateTime
  completedAt DateTime?

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId, status])
}

model TaskAssignment {
  id           String    @id @default(cuid())
  taskId       String
  userId       String
  role         String
  assignedById String?
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User  @relation("TaskAssignmentUser", fields: [userId], references: [id])
  assignedBy User? @relation("TaskAssignmentAssignedBy", fields: [assignedById], references: [id])

  @@index([taskId])
  @@index([userId])
}

model TaskDependency {
  id              String   @id @default(cuid())
  taskId          String
  dependsOnTaskId String
  dependencyType  String   @default("finish_to_start")
  createdById     String?
  createdAt       DateTime @default(now())

  task          Task @relation("TaskDependent", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskDependsOn", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

model TimeLog {
  id          String       @id @default(cuid())
  taskId      String
  userId      String
  workType    TaskWorkType @default(DEV)
  workDate    DateTime     @db.Date
  hours       Decimal      @db.Decimal(10, 2)
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId, workDate])
}

model Bug {
  id               String       @id @default(cuid())
  projectId        String
  taskId           String?
  bugCode          String
  title            String
  description      String?
  severity         BugSeverity  @default(MEDIUM)
  priority         TaskPriority @default(MEDIUM)
  status           BugStatus    @default(OPEN)
  environment      String?
  stepsToReproduce String?
  expectedResult   String?
  actualResult     String?

  reportedById String?
  reportedBy   User?   @relation("BugReportedBy", fields: [reportedById], references: [id])
  assignedToId String?
  assignedTo   User?   @relation("BugAssignedTo", fields: [assignedToId], references: [id])
  fixedById    String?
  fixedBy      User?   @relation("BugFixedBy", fields: [fixedById], references: [id])
  verifiedById String?
  verifiedBy   User?   @relation("BugVerifiedBy", fields: [verifiedById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?
  deletedAt DateTime?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  testResults TestResult[]

  @@unique([projectId, bugCode])
  @@index([projectId, status])
  @@index([taskId])
  @@index([severity])
}

model TestCase {
  id             String         @id @default(cuid())
  projectId      String
  taskId         String?
  requirementId  String?
  testCaseCode   String
  title          String
  precondition   String?
  steps          String?
  expectedResult String?
  priority       TaskPriority   @default(MEDIUM)
  status         TestCaseStatus @default(DRAFT)

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  results TestResult[]

  @@unique([projectId, testCaseCode])
  @@index([projectId, status])
  @@index([taskId])
}

model TestRun {
  id          String        @id @default(cuid())
  projectId   String
  sprintId    String?
  name        String
  status      TestRunStatus @default(PLANNED)
  startedAt   DateTime?
  completedAt DateTime?

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint  Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  results TestResult[]

  @@index([projectId, status])
}

model TestResult {
  id           String           @id @default(cuid())
  testRunId    String
  testCaseId   String
  taskId       String?
  result       TestResultStatus
  actualResult String?
  bugId        String?

  executedById String?
  executedBy   User?    @relation(fields: [executedById], references: [id])
  executedAt   DateTime @default(now())

  testRun  TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  bug      Bug?     @relation(fields: [bugId], references: [id], onDelete: SetNull)

  @@index([testRunId])
  @@index([testCaseId])
}

model DailyProjectSnapshot {
  id           String   @id @default(cuid())
  projectId    String
  snapshotDate DateTime @db.Date

  totalTasks      Int @default(0)
  completedTasks  Int @default(0)
  inProgressTasks Int @default(0)
  overdueTasks    Int @default(0)
  blockedTasks    Int @default(0)

  totalBugs    Int @default(0)
  openBugs     Int @default(0)
  closedBugs   Int @default(0)
  criticalBugs Int @default(0)

  totalEstimateHours Decimal @default(0) @db.Decimal(10, 2)
  totalActualHours   Decimal @default(0) @db.Decimal(10, 2)

  plannedProgressPercent Decimal @default(0) @db.Decimal(5, 2)
  actualProgressPercent  Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, snapshotDate])
  @@index([projectId, snapshotDate])
}

model Template {
  id          String    @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean   @default(false)
  structure   Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  projects Project[]

  @@index([isDefault])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String?
  projectId  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([projectId, createdAt])
  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  operation String
  provider  String   @default("openai")
  model     String

  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  totalTokens  Int @default(0)

  inputRateUsdPerMillion  Decimal @default(0) @db.Decimal(10, 4)
  outputRateUsdPerMillion Decimal @default(0) @db.Decimal(10, 4)
  costUsd                 Decimal @default(0) @db.Decimal(12, 6)

  metadata  Json?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([operation, createdAt])
  @@index([model, createdAt])
  @@index([createdAt])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
